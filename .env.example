# Traefik API URL (including port)
TRAEFIK_API_URL=http://traefik:8080

# Pi-hole URL (including port)
PIHOLE_URL=http://pihole:80

# Pi-hole admin password
PIHOLE_PASSWORD=your_password_here

# Sync interval in milliseconds (default: 60000 = 1 minute)
SYNC_INTERVAL=60000

# Default domain suffix for DNS records (not used anymore, kept for compatibility)
DEFAULT_DOMAIN=local

# Reverse proxy IPs (comma-separated, required) - the IP(s) of your reverse proxy
# Examples: 192.168.1.200 or 192.168.1.200,192.168.1.201
REVERSE_PROXY_IPS=192.168.1.200

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info
