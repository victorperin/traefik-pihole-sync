# Traefik API URL (including port)
TRAEFIK_API_URL=http://traefik:8080

# Pi-hole URL (including port)
PIHOLE_URL=http://pihole:80

# Pi-hole admin password
PIHOLE_PASSWORD=your_password_here

# Sync interval in milliseconds (default: 60000 = 1 minute)
SYNC_INTERVAL=60000

# Default domain suffix for DNS records
DEFAULT_DOMAIN=local
