{
  "name": "traefik-pihole-dns-sync",
  "version": "1.0.0",
  "description": "Synchronizes DNS records from Traefik to Pi-hole",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "debug": "node --inspect=9229 --use-system-ca -r ts-node/register src/index.ts",
    "debug:watch": "ts-node --inspect=xxx.xxx.xxx.xxx:9229 src/index.ts",
    "docker:build": "docker build -t traefik-pihole-dns-sync .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:debug": "docker-compose up --build",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "traefik",
    "pihole",
    "dns",
    "sync",
    "docker"
  ],
  "author": "",
  "license": "GPL-3.0",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "msw": "^2.12.13",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
